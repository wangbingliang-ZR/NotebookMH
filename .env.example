# NotebookMH 环境变量配置
# 复制此文件为 .env 并填入真实值

# AI 模型 API Key（二选一即可）
# DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# OpenAI（如使用 OpenAI 替代 DeepSeek）
# OPENAI_API_KEY=sk-your-openai-api-key-here

# AI 服务端点（默认 DeepSeek）
AI_BASE_URL=https://api.deepseek.com/v1

# 模型名称
AI_MODEL=deepseek-chat

# 可选：MOCK 模式开关（不配置 API Key 时自动启用）
# AI_MOCK=true
